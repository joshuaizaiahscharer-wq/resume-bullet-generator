{
  "version": 2,
  "crons": [
    { "path": "/api/cron/blog-generate", "schedule": "0 6 * * *" }
  ],
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/cron/blog-generate", "destination": "/api/index.js" },
    { "source": "/api/generate", "destination": "/api/index.js" },
    { "source": "/api/support", "destination": "/api/index.js" },
    { "source": "/check-my-resume", "destination": "/api/index.js" },
    { "source": "/auth/callback", "destination": "/api/index.js" },
    { "source": "/api/login", "destination": "/api/index.js" },
    { "source": "/api/logout", "destination": "/api/index.js" },
    { "source": "/api/callback", "destination": "/api/index.js" },
    { "source": "/api/auth/user", "destination": "/api/index.js" },
    { "source": "/api/admin/(.*)", "destination": "/api/index.js" },
    { "source": "/api/resume-builder/(.*)", "destination": "/api/index.js" },
    { "source": "/api/admin/support", "destination": "/api/index.js" },
    { "source": "/api/admin/usage", "destination": "/api/index.js" },
    { "source": "/api/admin/blog/generate", "destination": "/api/index.js" },
    { "source": "/api/resume-builder/access", "destination": "/api/index.js" },
    { "source": "/api/resume-builder/load-cloud", "destination": "/api/index.js" },
    { "source": "/api/resume-builder/save-cloud", "destination": "/api/index.js" },
    { "source": "/api/resume-builder/create-checkout-session", "destination": "/api/index.js" },
    { "source": "/api/check-resume", "destination": "/api/index.js" },
    { "source": "/api/fix-resume", "destination": "/api/index.js" },
    { "source": "/api/extract-resume-text", "destination": "/api/index.js" },
    { "source": "/api/download-optimized-resume", "destination": "/api/index.js" },
    { "source": "/api/stripe/checkout", "destination": "/api/index.js" },
    { "source": "/api/public-auth-config", "destination": "/api/index.js" },
    { "source": "/blog", "destination": "/api/index.js" },
    { "source": "/blog/(.*)", "destination": "/api/index.js" },
    { "source": "/jobs", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/api/index.js" },
    { "source": "/resume-template-builder", "destination": "/api/index.js" },
    { "source": "/resume-bullet-points-for-(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)-resume-summary-examples", "destination": "/api/index.js" },
    { "source": "/(.*)-skills-for-resume", "destination": "/api/index.js" },
    { "source": "/(.*)-cover-letter-examples", "destination": "/api/index.js" },
    { "source": "/(.*)-resume-bullets-no-experience", "destination": "/api/index.js" },
    { "source": "/robots.txt", "destination": "/api/index.js" },
    { "source": "/sitemap.xml", "destination": "/api/index.js" }
  ]
}
