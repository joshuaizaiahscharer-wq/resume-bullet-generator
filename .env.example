# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Port the server will listen on (optional, defaults to 3000)
PORT=3000

# Base URL for robots.txt and sitemap.xml
# Local: http://localhost:3000
# Production example: https://myresumebullets.com
SITE_URL=http://localhost:3000

# Supabase — server-side only. Add these in Vercel > Project Settings > Environment Variables.
# Get these from: Supabase Dashboard > Project Settings > API
# SUPABASE_URL     = the "Project URL" (e.g. https://xxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret key (NOT the anon key)
# WARNING: The service_role key bypasses Row Level Security — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin analytics dashboard password.
# The /admin page checks username "admin" client-side,
# then sends this password to /api/admin/usage for backend verification.
# Set this in Vercel > Project Settings > Environment Variables.
ADMIN_PASSWORD=
