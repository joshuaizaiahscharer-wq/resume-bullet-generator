# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key

# Port the server will listen on (optional, defaults to 3000)
PORT=3000

# Base URL for robots.txt and sitemap.xml
# Local: http://localhost:3000
# Production example: https://myresumebullets.com
SITE_URL=https://myresumebullets.com

# Shopify storefront URL used for direct Buy Now links.
# Example: https://your-store.myshopify.com/products/resume-template-pack
SHOPIFY_STORE_URL=https://your-store.myshopify.com/products/resume-template-pack

# Shopify webhook shared secret from Shopify Admin webhook settings.
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Download URL sent by email after a successful paid order.
# v1 uses a static URL; you can later replace with signed/expiring links.
PRODUCT_DOWNLOAD_URL=https://your-download-file-link

# SMTP settings for sending transactional emails.
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# From address shown in customer emails.
FROM_EMAIL=you@yourdomain.com
