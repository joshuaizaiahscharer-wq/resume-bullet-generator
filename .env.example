# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Port the server will listen on (optional, defaults to 3000)
PORT=3000

# Base URL for robots.txt and sitemap.xml
# Local: http://localhost:3000
# Production example: https://myresumebullets.com
SITE_URL=http://localhost:3000

# Supabase — server-side only. Add these in Vercel > Project Settings > Environment Variables.
# Get these from: Supabase Dashboard > Project Settings > API
# SUPABASE_URL     = the "Project URL" (e.g. https://xxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret key (NOT the anon key)
# SUPABASE_ANON_KEY (or SUPABASE_PUBLISHABLE_KEY) = public browser key for user sign-in
# WARNING: The service_role key bypasses Row Level Security — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Admin analytics dashboard password.
# The /admin page checks username "admin" client-side,
# then sends this password to /api/admin/usage and /api/admin/support for backend verification.
# Set this in Vercel > Project Settings > Environment Variables.
ADMIN_PASSWORD=

# Support request storage table (Supabase)
# create table if not exists public.support_requests (
#   id uuid default gen_random_uuid() primary key,
#   name text,
#   email text not null,
#   message text not null,
#   page_path text,
#   user_agent text,
#   ip_address text,
#   created_at timestamptz default now()
# );

# Email notifications for support requests (Gmail via Nodemailer)
# GMAIL_USER: your Gmail address used to send notifications
# GMAIL_APP_PASSWORD: generate at https://myaccount.google.com/apppasswords
#   (Google Account > Security > 2-Step Verification > App passwords)
# SUPPORT_NOTIFY_EMAIL: address to receive the notification (can be same as GMAIL_USER)
# Set all three in Vercel > Project Settings > Environment Variables.
GMAIL_USER=
GMAIL_APP_PASSWORD=
SUPPORT_NOTIFY_EMAIL=your-gmail@gmail.com

# Stripe Checkout for Resume Template Builder
# STRIPE_SECRET_KEY: secret API key from Stripe Dashboard (starts with sk_test_ or sk_live_)
# STRIPE_PRICE_ID: recurring/one-time price id to charge for unlocking resume template (starts with price_)
# PAYMENT_STATE_SECRET: long random string used to sign unlock cookie state
# RESUME_TEMPLATE_BUILDER_UNLOCKED=true can force unlock in development/testing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
PAYMENT_STATE_SECRET=
RESUME_TEMPLATE_BUILDER_UNLOCKED=false
